<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:focusable="false"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:translationZ="@dimen/qs_flip_tile_header_item_translationZ">
    <View
        android:id="@+id/header_divider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <TextView
        android:textSize="@dimen/qs_flip_tile_header_item_tv_title_text_size"
        android:textColor="@color/flip_qs_setting_header_title_color"
        android:gravity="start"
        android:layout_gravity="start"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="@dimen/qs_flip_tile_header_item_padding_horizontal"/>
    <TextView
        android:textSize="@dimen/qs_flip_tile_header_item_tv_sub_title_text_size"
        android:textColor="@color/flip_qs_setting_header_subtitle_color"
        android:gravity="start"
        android:layout_gravity="start"
        android:id="@+id/tv_sub_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/qs_flip_customize_header_sub_title"
        android:contentDescription="@string/qs_flip_customize_header_sub_title"
        android:fontFamily="sans-serif"
        android:paddingHorizontal="@dimen/qs_flip_tile_header_item_padding_horizontal"/>
</LinearLayout>
