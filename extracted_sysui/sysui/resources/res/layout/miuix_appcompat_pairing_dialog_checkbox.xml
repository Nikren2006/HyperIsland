<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pairingCheckboxContainer"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/miuix_appcompat_pairing_dialog_checkbox_padding_horizontal"
    android:paddingEnd="@dimen/miuix_appcompat_pairing_dialog_checkbox_padding_horizontal">
    <androidx.appcompat.widget.AppCompatCheckBox
        android:id="@+id/pairing_checkbox_stub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/miuix_appcompat_dialog_checkbox_vertical_margin"
        android:drawablePadding="@dimen/miuix_appcompat_dialog_checkbox_inner_padding"
        style="?attr/dialogCheckBoxStyle"/>
</LinearLayout>
