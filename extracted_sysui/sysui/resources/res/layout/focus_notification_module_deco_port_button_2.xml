<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/line"
        android:background="@color/lineColor"
        android:layout_width="match_parent"
        android:layout_height="@dimen/focus_notify_line_height"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4.38dp"
        android:baselineAligned="false">
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:id="@+id/layout_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp">
            <FrameLayout
                android:orientation="vertical"
                android:id="@+id/title_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/focus_small_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/FocusNotifyDecoLandSmallTitleStyleV2"/>
                <miuix.colorful.texteffect.HyperChronometer
                    android:id="@+id/chronometer_hint"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/FocusNotifyDecoLandSmallChronometerStyleV2"/>
            </FrameLayout>
            <TextView
                android:id="@+id/focus_small_subtitle"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                style="@style/FocusNotifyDecoLandSmallTitleStyleV2"/>
        </LinearLayout>
        <TextView
            android:id="@+id/focus_text_title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:fontFamily="mipro-demibold"
            style="@style/FocusNotifyDecoPortButton3TitleStyleV2"/>
        <include
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            layout="@layout/focus_notification_module_deco_port_mark_4"/>
    </LinearLayout>
</FrameLayout>
