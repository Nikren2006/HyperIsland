<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container"
    android:layout_width="@dimen/focus_notify_deco_port_width"
    android:layout_height="@dimen/focus_notify_deco_port_height">
    <ImageView
        android:id="@+id/focus_notify_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/focus_main_column"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/focus_bottom_container"
        android:layout_alignParentTop="true"
        android:layout_marginHorizontal="@dimen/focus_notify_deco_port_margin">
        <TextView
            android:id="@+id/focus_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="3"
            android:textAlignment="center"
            android:paddingHorizontal="@dimen/focus_notify_deco_port_title_padding"
            android:paddingVertical="@dimen/focus_notify_deco_port_title_padding_vertical"
            style="@style/FocusNotifyDecoPortTitleStyle"/>
        <TextView
            android:id="@+id/focus_content_sos"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="3"
            android:textAlignment="center"
            android:paddingVertical="@dimen/focus_notify_deco_port_title_padding_vertical"
            style="@style/FocusNotifyDecoPortContentStyle"/>
        <TextView
            android:id="@+id/focus_desc1"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/focus_notify_deco_port_title_margin_top"
            android:textAlignment="center"
            style="@style/FocusNotifyDecoPortContentStyle"/>
        <TextView
            android:id="@+id/focus_desc2"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/focus_content"
            android:textAlignment="center"
            style="@style/FocusNotifyDecoPortContentStyle"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/focus_bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <ImageView
            android:id="@+id/focus_button_icon1"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/focus_notify_deco_port_button_margin_top"/>
        <ImageView
            android:id="@+id/focus_button_icon2"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/focus_notify_deco_port_button_margin_bottom"/>
        <ImageView
            android:id="@+id/focus_large_icon"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="@dimen/focus_notify_deco_port_large_icon_height"
            android:layout_height="@dimen/focus_notify_deco_port_large_icon_height"
            android:layout_marginBottom="@dimen/focus_notify_deco_port_button_margin_bottom"
            android:importantForAccessibility="no"/>
    </LinearLayout>
</RelativeLayout>
