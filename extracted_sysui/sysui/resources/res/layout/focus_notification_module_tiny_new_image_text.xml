<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/focus_container_module_new_image_text"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/focus_icon_container"
        android:layout_width="@dimen/focus_notify_tiny_profile_container_size"
        android:layout_height="@dimen/focus_notify_tiny_profile_container_size">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/focus_profile"
            android:visibility="gone"
            android:layout_width="@dimen/focus_notify_tiny_profile_picture_size"
            android:layout_height="@dimen/focus_notify_tiny_profile_picture_size"/>
        <miui.systemui.widget.TextureVideoView
            android:layout_gravity="center"
            android:id="@+id/focus_video"
            android:visibility="gone"
            android:layout_width="@dimen/focus_notify_tiny_profile_picture_size"
            android:layout_height="@dimen/focus_notify_tiny_profile_picture_size"/>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/focus_title_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/focus_notify_tiny_title_container_margin_top"
        android:layout_marginStart="@dimen/focus_notify_tiny_title_container_margin_start">
        <TextView
            android:id="@+id/focus_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            style="@style/FocusNotifyTitleTinyStyleV3"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/focus_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxEms="6"
                android:singleLine="true"
                style="@style/FocusNotifyContentStyleV2"/>
            <TextView
                android:id="@+id/focus_sub_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxEms="6"
                android:singleLine="true"
                android:layout_marginStart="@dimen/focus_notify_module_margin_horizontal"
                style="@style/FocusNotifyContentStyleV2"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
