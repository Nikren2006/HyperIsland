<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container"
    android:layout_width="@dimen/focus_notify_deco_land_width"
    android:layout_height="@dimen/focus_notify_deco_land_height">
    <ImageView
        android:id="@+id/focus_notify_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/focus_main_column"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/focus_bottom_container"
        android:layout_alignParentTop="true"
        android:layout_marginHorizontal="@dimen/focus_notify_deco_land_margin_start">
        <TextView
            android:id="@+id/focus_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/focus_title"
            android:textAlignment="center"
            style="@style/FocusNotifyDecoTitleStyle"/>
        <TextView
            android:id="@+id/focus_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/focus_content"
            android:textAlignment="center"
            style="@style/FocusNotifyDecoContentStyle"/>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:id="@+id/focus_bottom_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true">
        <ImageView
            android:id="@+id/focus_button_icon1"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/focus_notify_deco_land_button_margin_bottom"/>
        <ImageView
            android:id="@+id/focus_button_icon2"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/focus_notify_deco_land_button_margin_bottom"
            android:layout_marginStart="@dimen/focus_notify_deco_land_button_margin"/>
    </LinearLayout>
</RelativeLayout>
