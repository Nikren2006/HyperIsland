<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:id="@+id/focus_container_module_image_text_im"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/focus_notify_deco_land_progress_margin_horizontal">
    <TextView
        android:id="@+id/focus_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxEms="12"
        android:fontFamily="mipro-demibold"
        style="@style/FocusNotifyDecoTitleStyleV2"/>
    <TextView
        android:gravity="center"
        android:id="@+id/focus_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxEms="18"
        style="@style/FocusNotifyDecoImContentStyleV2"/>
    <miuix.colorful.texteffect.HyperChronometer
        android:textColor="@color/miuix_color_green_dark_primary_default"
        android:layout_gravity="center_horizontal"
        android:id="@+id/chronometer"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        style="@style/FocusNotifyDecoContentChronometerStyleV2"/>
</LinearLayout>
