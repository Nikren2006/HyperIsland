<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:id="@+id/island_container_module_image_text_1"
    android:layout_width="wrap_content"
    android:layout_height="match_parent">
    <miui.systemui.widget.CircularProgressBar
        android:layout_gravity="center"
        android:id="@+id/island_progress"
        android:layout_width="28dp"
        android:layout_height="28dp"/>
    <include
        android:layout_gravity="center"
        android:id="@+id/island_icon_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        layout="@layout/dynamic_island_module_icon_1"/>
    <include
        android:id="@+id/island_icon_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        layout="@layout/dynamic_island_module_icon_1"/>
</FrameLayout>
