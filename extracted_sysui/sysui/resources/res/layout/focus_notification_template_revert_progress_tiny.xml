<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container"
    android:layout_width="match_parent"
    android:layout_height="@dimen/focus_notify_normal_height_tiny">
    <ImageView
        android:id="@+id/focus_notify_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <RelativeLayout
        android:layout_gravity="top"
        android:id="@+id/focus_main_column"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/focus_notify_tiny_margin_start">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/focus_title_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/focus_pics_container"
            android:layout_alignParentStart="true">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/title_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/focus_notify_tiny_margin_top_template_progress">
                <TextView
                    android:id="@+id/focus_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/focus_title"
                    android:maxEms="10"
                    android:layout_marginEnd="@dimen/focus_notify_view_gap"
                    style="@style/FocusNotifyTinyProgressTitleStyle"/>
                <TextView
                    android:id="@+id/focus_subtitle"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/focus_sub_title"
                    style="@style/FocusNotifyTinyProgressContentStyle"/>
            </LinearLayout>
            <TextView
                android:id="@+id/focus_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/focus_notify_tiny_margin_bottom_template_progress"
                android:text="@string/focus_content"
                style="@style/FocusNotifyTinyProgressContentStyle"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/focus_pics_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginEnd="@dimen/focus_notify_tiny_margin_end_template_progress"
            android:layout_alignParentEnd="true">
            <ImageView
                android:id="@+id/focus_small_icon"
                android:layout_width="@dimen/focus_notify_tiny_small_icon_height"
                android:layout_height="@dimen/focus_notify_tiny_small_icon_height"
                android:layout_marginTop="@dimen/focus_notify_tiny_margin_top_template_progress"
                android:importantForAccessibility="no"
                android:layout_marginStart="@dimen/focus_notify_small_icon_margin_start"/>
        </LinearLayout>
        <TextView
            android:id="@+id/focus_desc"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="@string/focus_desc"
            android:layout_below="@+id/focus_title_container"
            style="@style/FocusNotifyDescStyle"/>
        <LinearLayout
            android:id="@+id/progressbar_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/focus_notify_tiny_progress_container_height"
            android:layout_marginBottom="@dimen/focus_notify_tiny_margin_bottom_progress"
            android:layout_below="@+id/focus_title_container"
            android:importantForAccessibility="no"
            android:layout_marginEnd="@dimen/focus_notify_tiny_margin_end_progress">
            <ProgressBar
                android:layout_gravity="center_vertical"
                android:id="@+id/focus_progress_info1"
                android:layout_width="0dp"
                android:layout_height="@dimen/focus_notify_progress_height"
                android:progressDrawable="@drawable/progressbar_style"
                android:layout_weight="1"
                style="?android:attr/progressBarStyleHorizontal"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/progress_point1"
                android:layout_width="@dimen/focus_notify_tiny_progress_point_height"
                android:layout_height="@dimen/focus_notify_tiny_progress_point_height"
                android:src="@drawable/point_unselect"/>
            <ProgressBar
                android:layout_gravity="center_vertical"
                android:id="@+id/focus_progress_info2"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="@dimen/focus_notify_progress_height"
                android:progressDrawable="@drawable/progressbar_style"
                android:layout_weight="1"
                style="?android:attr/progressBarStyleHorizontal"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/progress_point2"
                android:visibility="gone"
                android:layout_width="@dimen/focus_notify_tiny_progress_point_height"
                android:layout_height="@dimen/focus_notify_tiny_progress_point_height"
                android:src="@drawable/point_unselect"/>
        </LinearLayout>
    </RelativeLayout>
</FrameLayout>
