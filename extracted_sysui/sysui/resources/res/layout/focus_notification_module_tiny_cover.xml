<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/focus_container_module_cover"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/focus_icon_container"
        android:layout_width="33dp"
        android:layout_height="43dp">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/focus_profile"
            android:layout_width="29dp"
            android:layout_height="39dp"/>
    </FrameLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/focus_title_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginStart="4dp">
        <miuix.colorful.texteffect.TimerTextEffectView
            android:id="@+id/focus_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxEms="8"
            style="@style/FocusNotifyTitleTinyStyleV3"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/focus_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxEms="5"
                android:singleLine="true"
                style="@style/FocusNotifyContentStyleV2"/>
            <TextView
                android:id="@+id/focus_sub_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxEms="4"
                android:singleLine="true"
                android:layout_marginStart="@dimen/focus_notify_module_margin_horizontal"
                style="@style/FocusNotifyContentStyleV2"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
