<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/tiny_content_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/focus_notify_module_tiny_margin_horizontal"
    android:layout_marginEnd="4dp">
    <TextView
        android:id="@+id/focus_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="mipro-demibold"
        style="@style/FocusNotifyTinyContentStyleV2"/>
    <TextView
        android:id="@+id/focus_sub_content_divider"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:text="|"
        android:layout_marginStart="@dimen/focus_notify_tiny_text_margin_horizontal"
        style="@style/FocusNotifyTinyContentStyleV2"/>
    <TextView
        android:id="@+id/focus_sub_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/FocusNotifyTinyContentStyleV2"/>
    <TextView
        android:id="@+id/focus_function_icon_divider"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:text="|"
        android:layout_marginStart="@dimen/focus_notify_tiny_text_margin_horizontal"
        style="@style/FocusNotifyTinyContentStyleV2"/>
    <ImageView
        android:id="@+id/focus_function_icon"
        android:visibility="gone"
        android:layout_width="@dimen/focus_notify_function_icon_size"
        android:layout_height="@dimen/focus_notify_function_icon_size"
        android:importantForAccessibility="no"
        android:layout_marginStart="@dimen/focus_notify_tiny_text_margin_horizontal"/>
</LinearLayout>
