<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/focus_container_module_text_1"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="2dp">
        <TextView
            android:id="@+id/focus_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="mipro-demibold"
            style="@style/FocusNotifyDecoContentStyleV2"/>
        <TextView
            android:id="@+id/focus_sub_content"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            style="@style/FocusNotifyDecoContentStyleV2"/>
    </LinearLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/focus_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/focus_special_title"
            style="@style/FocusNotifyDecoTitleStyleV2"/>
        <TextView
            android:gravity="center_vertical"
            android:id="@+id/focus_special_title"
            android:background="@drawable/focus_deco_prot_text_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxEms="12"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:layout_marginHorizontal="2dp"
            android:paddingHorizontal="4dp"
            android:paddingVertical="1dp"
            style="@style/FocusNotifyDecoSpecialTextStyleV2"/>
    </RelativeLayout>
</LinearLayout>
