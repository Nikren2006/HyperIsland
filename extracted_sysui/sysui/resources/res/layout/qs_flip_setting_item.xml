<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="@dimen/qs_flip_tile_item_width"
    android:layout_height="@dimen/qs_flip_tile_item_height"
    android:hapticFeedbackEnabled="false"
    android:importantForAccessibility="yes"
    android:layout_marginStart="@dimen/qs_flip_tile_item_margin_start">
    <androidx.cardview.widget.CardView
        android:id="@+id/iv_icon_cardView"
        android:layout_width="@dimen/qs_flip_tile_item_iv_icon_card_view_width"
        android:layout_height="@dimen/qs_flip_tile_item_iv_icon_card_view_height"
        android:layout_marginTop="@dimen/qs_flip_tile_item_iv_icon_card_view_margin_top"
        android:layout_centerHorizontal="true"
        android:importantForAccessibility="no"
        app:cardBackgroundColor="@color/flip_qs_setting_tile_icon_bg_color"
        app:cardCornerRadius="@dimen/qs_flip_tile_item_iv_icon_card_corner_radius"
        app:cardElevation="@dimen/qs_flip_tile_item_iv_icon_card_elevation">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/iv_icon"
            android:layout_width="@dimen/qs_flip_tile_item_iv_icon_width"
            android:layout_height="@dimen/qs_flip_tile_item_iv_icon_height"
            android:importantForAccessibility="no"/>
    </androidx.cardview.widget.CardView>
    <ImageView
        android:id="@+id/iv_operation"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="@dimen/qs_flip_tile_item_iv_operation_width"
        android:layout_height="@dimen/qs_flip_tile_item_iv_operation_width"
        android:layout_marginTop="@dimen/qs_flip_tile_item_iv_operation_margin_top"
        android:layout_alignTop="@+id/iv_icon_cardView"
        android:importantForAccessibility="no"
        android:layout_marginEnd="@dimen/qs_flip_tile_item_iv_operation_margin_end"
        android:layout_alignEnd="@+id/iv_icon_cardView"
        android:screenReaderFocusable="true"/>
    <TextView
        android:textSize="@dimen/qs_flip_tile_item_tv_title_text_size"
        android:textColor="@color/flip_qs_setting_tile_text_color"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/qs_flip_tile_item_tv_title_margin_top"
        android:singleLine="true"
        android:layout_below="@+id/iv_icon_cardView"
        android:layout_centerHorizontal="true"
        android:importantForAccessibility="no"
        android:fontFamily="sans-serif-medium"/>
</RelativeLayout>
