<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@+id/focus_container_module_animation_text"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/focus_icon_container"
        android:layout_width="30dp"
        android:layout_height="30dp">
        <com.airbnb.lottie.LottieAnimationView
            android:layout_gravity="center"
            android:id="@+id/focus_animation"
            android:layout_width="25.71dp"
            android:layout_height="25.71dp"
            app:lottie_autoPlay="false"/>
    </FrameLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="40dp">
        <miui.systemui.notification.HyperChronometerPlugin
            android:gravity="center"
            android:id="@+id/chronometer"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/FocusNotifyTimeDecoStyleV3"/>
        <miuix.colorful.texteffect.TimerTextEffectView
            android:gravity="center"
            android:id="@+id/focus_title"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxEms="6"
            style="@style/FocusNotifyTimeTinyStyleV3"/>
        <miuix.colorful.texteffect.TimerTextEffectView
            android:textSize="12dp"
            android:gravity="center"
            android:id="@+id/focus_content"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxEms="6"
            style="@style/FocusNotifyContentStyleV2"/>
    </LinearLayout>
</LinearLayout>
