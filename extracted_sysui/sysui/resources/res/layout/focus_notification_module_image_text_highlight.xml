<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container_module_image_text_highlight"
    android:visibility="gone"
    android:layout_width="@dimen/focus_view_over_screen_width"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/focus_notify_module_margin_horizontal">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/focus_title_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:gravity="bottom"
            android:id="@+id/focus_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxEms="12"
            style="@style/FocusNotifyHighlightStyleV2"/>
        <miuix.colorful.texteffect.HyperChronometer
            android:gravity="start|bottom"
            android:id="@+id/chronometer"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/FocusNotifyHighlightChronometerStyleV2"/>
        <TextView
            android:id="@+id/focus_content"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/focus_notify_content_height"
            android:maxEms="12"
            android:layout_marginStart="@dimen/focus_notify_module_margin_horizontal"
            style="@style/FocusNotifyAccessoryStyleV2"/>
        <ImageView
            android:layout_gravity="bottom"
            android:id="@+id/focus_function_icon"
            android:visibility="gone"
            android:layout_width="@dimen/focus_notify_function_icon_size"
            android:layout_height="@dimen/focus_notify_function_icon_size"
            android:layout_marginBottom="6dp"
            android:layout_marginStart="@dimen/focus_notify_module_margin_horizontal"/>
        <TextView
            android:id="@+id/focus_sub_content"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/focus_notify_content_height"
            android:maxEms="12"
            android:layout_marginStart="@dimen/focus_notify_module_margin_horizontal"
            style="@style/FocusNotifyAccessoryStyleV2"/>
    </LinearLayout>
</FrameLayout>
