<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container"
    android:layout_width="@dimen/focus_notify_deco_port_width"
    android:layout_height="@dimen/focus_notify_deco_port_height">
    <ImageView
        android:id="@+id/focus_notify_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/focus_notify_deco_port_margin"
            android:layout_marginHorizontal="@dimen/focus_notify_deco_port_margin">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/focus_pics_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/focus_notify_deco_port_icon_margin">
                <ImageView
                    android:id="@+id/focus_small_icon"
                    android:layout_width="@dimen/focus_notify_deco_port_icon_height"
                    android:layout_height="@dimen/focus_notify_deco_port_icon_height"
                    android:importantForAccessibility="no"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/focus_title_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/focus_notify_deco_port_title_container_margin_top">
                <TextView
                    android:id="@+id/focus_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/focus_title"
                    style="@style/FocusNotifyDecoPortTitleStyle"/>
                <TextView
                    android:id="@+id/focus_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/focus_notify_deco_port_title_margin_top"
                    android:text="@string/focus_content"
                    style="@style/FocusNotifyDecoPortContentStyle"/>
            </LinearLayout>
        </LinearLayout>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_gravity="bottom"
                android:id="@+id/progressbar_container"
                android:layout_width="match_parent"
                android:layout_height="@dimen/focus_notify_deco_port_progress_container_height"
                android:layout_marginBottom="@dimen/focus_notify_deco_port_progress_container_margin_bottom"
                android:importantForAccessibility="no"
                android:layout_marginHorizontal="@dimen/focus_notify_deco_port_progress_container_margin_horizontal">
                <ProgressBar
                    android:layout_gravity="center_vertical"
                    android:id="@+id/focus_progress_info1"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/focus_notify_deco_port_progress_height"
                    android:progressDrawable="@drawable/progressbar_style"
                    android:layout_weight="1"
                    style="?android:attr/progressBarStyleHorizontal"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/progress_point1"
                    android:layout_width="@dimen/focus_notify_deco_port_progress_point_height"
                    android:layout_height="@dimen/focus_notify_deco_port_progress_point_height"
                    android:src="@drawable/point_unselect"/>
                <ProgressBar
                    android:layout_gravity="center_vertical"
                    android:id="@+id/focus_progress_info2"
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/focus_notify_deco_port_progress_height"
                    android:progressDrawable="@drawable/progressbar_style"
                    android:layout_weight="1"
                    style="?android:attr/progressBarStyleHorizontal"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/progress_point2"
                    android:visibility="gone"
                    android:layout_width="@dimen/focus_notify_deco_port_progress_point_height"
                    android:layout_height="@dimen/focus_notify_deco_port_progress_point_height"
                    android:src="@drawable/point_unselect"/>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
