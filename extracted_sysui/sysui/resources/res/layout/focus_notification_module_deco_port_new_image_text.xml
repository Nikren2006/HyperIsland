<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/focus_container_module_new_image_text"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_horizontal"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/focus_title_container"
        android:layout_width="@dimen/focus_notify_deco_port_icon_text_width"
        android:layout_height="wrap_content">
        <FrameLayout
            android:id="@+id/focus_icon_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/focus_profile"
                android:visibility="gone"
                android:layout_width="@dimen/focus_notify_profile_picture_size"
                android:layout_height="@dimen/focus_notify_profile_picture_size"/>
            <miui.systemui.widget.TextureVideoView
                android:layout_gravity="center"
                android:id="@+id/focus_video"
                android:visibility="gone"
                android:layout_width="@dimen/focus_notify_profile_picture_size"
                android:layout_height="@dimen/focus_notify_profile_picture_size"/>
        </FrameLayout>
        <TextView
            android:id="@+id/focus_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/focus_notify_deco_port_icon_text_margin"
            android:maxLines="2"
            style="@style/FocusNotifyTitleDecoStyleV3"/>
        <TextView
            android:id="@+id/focus_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/focus_notify_deco_port_icon_margin"
            android:maxLines="2"
            style="@style/FocusNotifyContentDecoStyleV3"/>
        <TextView
            android:id="@+id/focus_sub_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            style="@style/FocusNotifyContentDecoStyleV3"/>
    </LinearLayout>
</LinearLayout>
