<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container"
    android:layout_width="@dimen/focus_notify_deco_port_width"
    android:layout_height="@dimen/focus_notify_deco_port_height">
    <ImageView
        android:id="@+id/focus_notify_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/focus_main_column"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/focus_bottom_container"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true">
        <TextView
            android:gravity="center"
            android:id="@+id/focus_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/focus_content"
            android:textAlignment="center"
            android:paddingStart="@dimen/focus_notify_deco_port_button_margin_bottom"
            android:paddingEnd="@dimen/focus_notify_deco_port_button_margin_bottom"
            style="@style/FocusNotifyDecoContentStyle"/>
        <TextView
            android:textSize="22dp"
            android:gravity="center"
            android:id="@+id/focus_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/focus_title"
            android:fontFamily="mipro-medium"
            style="@style/FocusNotifyTitleStyle"/>
        <Chronometer
            android:id="@+id/chronometer"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/focus_notify_deco_port_title_padding"
            style="@style/FocusNotifyCmStyle"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/focus_bottom_container"
        android:paddingBottom="@dimen/focus_notify_deco_port_bottom_container_margin_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true">
        <ImageView
            android:id="@+id/focus_button_icon1"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <ImageView
            android:id="@+id/focus_button_icon2"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/focus_notify_deco_port_button_margin_top"/>
    </LinearLayout>
</RelativeLayout>
