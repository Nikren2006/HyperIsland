<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:layout_gravity="center_vertical"
    android:orientation="horizontal"
    android:id="@+id/focus_container_module_button"
    android:visibility="gone"
    android:layout_width="wrap_content"
    android:layout_height="@dimen/focus_notify_tiny_action_size">
    <miui.systemui.widget.AnimateImageView
        android:id="@+id/focus_button_icon1"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="@dimen/focus_notify_tiny_action_size"
        android:layout_height="@dimen/focus_notify_tiny_action_size"/>
    <miui.systemui.widget.StatusProgressLayout
        android:layout_gravity="center_horizontal"
        android:id="@+id/focus_button_progress1"
        android:visibility="gone"
        android:layout_width="@dimen/focus_notify_tiny_action_size"
        android:layout_height="@dimen/focus_notify_tiny_action_size"
        app:maxProgress="100"
        app:pbCircleColor="@color/color_progressbar"
        app:progressbarColor="@color/progress_color"
        app:strokeWidth="3.71dp"/>
    <miui.systemui.widget.AnimateImageView
        android:id="@+id/focus_button_icon2"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="@dimen/focus_notify_tiny_action_size"
        android:layout_height="@dimen/focus_notify_tiny_action_size"
        android:layout_marginStart="@dimen/focus_notify_tiny_button_margin_start"/>
    <miui.systemui.widget.StatusProgressLayout
        android:layout_gravity="center_horizontal"
        android:id="@+id/focus_button_progress2"
        android:visibility="gone"
        android:layout_width="@dimen/focus_notify_tiny_action_size"
        android:layout_height="@dimen/focus_notify_tiny_action_size"
        android:layout_marginStart="10dp"
        app:maxProgress="100"
        app:pbCircleColor="@color/color_progressbar"
        app:progressbarColor="@color/progress_color"
        app:strokeWidth="3.71dp"/>
    <include
        android:id="@+id/focus_button_container_action"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        layout="@layout/focus_notification_module_tiny_mark_5"/>
</LinearLayout>
