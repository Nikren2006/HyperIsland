<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_button_container"
    android:background="@drawable/focus_button_background"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:gravity="center"
        android:id="@+id/focus_button_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/focus_title"
        android:maxEms="4"
        android:textAlignment="center"
        android:layout_marginHorizontal="@dimen/focus_notify_button_without_icon_margin_start"
        android:layout_marginVertical="6.5dp"
        style="@style/FocusNotifyButtonTitleStyleV2"/>
</FrameLayout>
