<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/device_controls_sense_edit_item_container_height">
    <RelativeLayout
        android:layout_gravity="start|bottom"
        android:id="@+id/item"
        android:background="@drawable/control_background_edit"
        android:focusable="true"
        android:clickable="false"
        android:layout_width="match_parent"
        android:layout_height="@dimen/device_controls_sense_edit_item_height"
        android:layout_marginEnd="@dimen/miui_controls_edit_item_margin_end"
        android:screenReaderFocusable="true">
        <ImageView
            android:id="@+id/icon"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="@dimen/device_controls_sense_item_icon_size"
            android:layout_height="@dimen/device_controls_sense_item_icon_size"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/device_controls_sense_item_icon_margin_start"
            android:layout_alignParentStart="true"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/device_controls_sense_item_title_margin_start"
            android:layout_alignParentStart="true">
            <TextView
                android:textAppearance="@style/TextAppearance.Control.Edit.Title"
                android:ellipsize="end"
                android:gravity="start|center_vertical"
                android:id="@+id/title"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textAlignment="viewStart"/>
            <TextView
                android:textAppearance="@style/TextAppearance.ControlEdit.Subtitle"
                android:ellipsize="end"
                android:gravity="start|center_vertical"
                android:id="@+id/subtitle"
                android:focusable="false"
                android:clickable="false"
                android:layout_width="@dimen/device_controls_edit_item_title_width"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/device_controls_edit_item_title_margin_top"
                android:maxLines="1"/>
        </LinearLayout>
    </RelativeLayout>
    <ImageView
        android:layout_gravity="end|top"
        android:id="@+id/mark"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</FrameLayout>
