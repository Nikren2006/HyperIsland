<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:id="@+id/focus_container_module_animation_text"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/focus_icon_container"
        android:layout_width="@dimen/focus_notify_profile_container_size"
        android:layout_height="@dimen/focus_notify_profile_container_size">
        <com.mi.widget.view.LottieView
            android:layout_gravity="center"
            android:id="@+id/focus_animation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:frameRate="rate120"
            app:lottie_autoPlay="false"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/focus_animation_static"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/focus_title_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/focus_notify_module_margin_horizontal_area_a">
        <miui.systemui.notification.HyperChronometerPlugin
            android:id="@+id/chronometer"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/FocusNotifyCmStyle"/>
        <miuix.colorful.texteffect.TimerTextEffectView
            android:id="@+id/focus_title"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxEms="12"
            style="@style/FocusNotifyTitleStyleV3"/>
        <miuix.colorful.texteffect.TimerTextEffectView
            android:id="@+id/focus_content"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/FocusNotifyContentStyleV2"/>
    </LinearLayout>
</LinearLayout>
