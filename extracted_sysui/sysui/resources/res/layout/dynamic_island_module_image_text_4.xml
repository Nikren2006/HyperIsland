<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="end|center_vertical"
    android:orientation="horizontal"
    android:id="@+id/island_container_module_image_text_1"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_marginEnd="@dimen/effect_view_margin">
    <com.mi.widget.view.PowerSaveView
        android:layout_gravity="end|center_vertical"
        android:id="@+id/power_save_view"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <com.mi.widget.view.ChargerView
        android:layout_gravity="end|center_vertical"
        android:id="@+id/charge_view"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</FrameLayout>
