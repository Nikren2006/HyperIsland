<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container"
    android:layout_width="match_parent"
    android:layout_height="@dimen/focus_notify_normal_height_tiny">
    <ImageView
        android:id="@+id/focus_notify_bg_image"
        android:layout_width="match_parent"
        android:layout_height="@dimen/focus_notify_normal_height_tiny"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:layout_gravity="top"
        android:orientation="vertical"
        android:id="@+id/focus_main_column"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/focus_notify_tiny_margin_top_revert"
        android:layout_marginBottom="@dimen/focus_notify_tiny_margin_bottom_revert"
        android:layout_marginStart="@dimen/focus_notify_tiny_margin_start">
        <TextView
            android:id="@+id/focus_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/focus_content"
            android:maxEms="8"
            style="@style/FocusNotifyTinyRevertContentStyle"/>
        <TextView
            android:id="@+id/focus_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/focus_title"
            android:maxEms="6"
            style="@style/FocusNotifyTinyRevertTitleStyle"/>
        <Chronometer
            android:id="@+id/chronometer"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/FocusNotifyTinyRevertTitleStyle"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="end|center_vertical"
        android:layout_gravity="end|center_vertical"
        android:id="@+id/focus_right_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/focus_notify_tiny_margin_start_revert"
        android:layout_marginEnd="@dimen/focus_notify_tiny_margin_end_revert">
        <ImageView
            android:id="@+id/focus_button_icon1"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="@dimen/focus_notify_tiny_action_height"
            android:layout_height="@dimen/focus_notify_tiny_action_height"/>
        <ImageView
            android:id="@+id/focus_button_icon2"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="@dimen/focus_notify_tiny_action_height"
            android:layout_height="@dimen/focus_notify_tiny_action_height"
            android:layout_marginStart="6dp"/>
        <ImageView
            android:layout_gravity="end|center_vertical"
            android:id="@+id/focus_large_icon"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="@dimen/focus_notify_tiny_large_pic_height"
            android:layout_height="@dimen/focus_notify_tiny_large_pic_height"
            android:importantForAccessibility="no"
            android:layout_marginEnd="@dimen/focus_notify_tiny_margin_end_revert"/>
    </LinearLayout>
</FrameLayout>
