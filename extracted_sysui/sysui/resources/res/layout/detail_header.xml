<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:id="@+id/detail_header"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/detail_panel_padding_vertical"
    android:layout_marginBottom="@dimen/qs_detail_header_margin_bottom"
    android:importantForAccessibility="yes"
    android:layout_marginHorizontal="@dimen/detail_panel_padding_vertical">
    <TextView
        android:textAppearance="@style/TextAppearance.Detail.Header"
        android:ellipsize="end"
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:layout_weight="1"
        android:textAlignment="viewStart"/>
    <miui.systemui.controlcenter.widget.SlidingButton
        android:id="@android:id/toggle"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:layout_marginStart="@dimen/qs_detail_header_slider_margin_start"/>
</LinearLayout>
