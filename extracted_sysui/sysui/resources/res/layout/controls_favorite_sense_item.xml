<?xml version="1.0" encoding="utf-8"?>
<miui.systemui.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/control_background"
    android:focusable="true"
    android:clickable="false"
    android:layout_width="@dimen/device_controls_item_width"
    android:layout_height="@dimen/device_controls_sense_item_height"
    android:screenReaderFocusable="true">
    <View
        android:id="@+id/v_ripple"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <ImageView
        android:id="@+id/icon"
        android:focusable="false"
        android:clickable="false"
        android:layout_width="@dimen/device_controls_sense_item_icon_size"
        android:layout_height="@dimen/device_controls_sense_item_icon_size"
        android:layout_marginStart="@dimen/device_controls_sense_item_icon_margin_start"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textAppearance="@style/TextAppearance.Control.Device.Title"
        android:ellipsize="end"
        android:gravity="start|center_vertical"
        android:id="@+id/title"
        android:focusable="false"
        android:clickable="false"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:textAlignment="viewStart"
        android:layout_marginStart="@dimen/device_controls_sense_item_title_margin_start"
        android:layout_marginEnd="@dimen/device_controls_item_title_margin_horizontal"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="@dimen/device_controls_item_title_min_text_size"
        android:autoSizeMaxTextSize="@dimen/device_controls_item_title_max_text_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_status"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/title"
        android:alpha="0.5"
        android:layout_alignParentStart="true"
        app:layout_constraintLeft_toLeftOf="@+id/title"
        app:layout_constraintTop_toBottomOf="@+id/title">
        <TextView
            android:textAppearance="@style/TextAppearance.Control.Device.Subtitle"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/subtitle"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:singleLine="true"
            android:screenReaderFocusable="false"/>
        <View
            android:layout_gravity="center_vertical"
            android:id="@+id/v_border"
            android:background="@color/control_primary_text"
            android:layout_width="@dimen/device_controls_item_border_width"
            android:layout_height="@dimen/device_controls_item_border_height"
            android:layout_marginHorizontal="@dimen/device_controls_item_border_margin_horizontal"/>
        <TextView
            android:textAppearance="@style/TextAppearance.Control.Device.Status"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/status"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:screenReaderFocusable="false"/>
    </LinearLayout>
</miui.systemui.widget.ConstraintLayout>
