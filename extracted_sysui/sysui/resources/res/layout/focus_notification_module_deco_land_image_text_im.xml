<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/focus_container_module_image_text_im"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/focus_notify_deco_land_progress_margin_horizontal">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/spaceTextViewCenter1"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <TextView
            android:id="@+id/focus_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxEms="12"
            android:fontFamily="mipro-demibold"
            style="@style/FocusNotifyDecoTitleStyleV2"/>
        <TextView
            android:id="@+id/spaceTextViewCenter2"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
    </LinearLayout>
    <TextView
        android:id="@+id/focus_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxEms="12"
        style="@style/FocusNotifyDecoImContentStyleV2"/>
    <miuix.colorful.texteffect.HyperChronometer
        android:layout_gravity="center_horizontal"
        android:id="@+id/chronometer"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/FocusNotifyTinyContentChronometerStyleV2"/>
</LinearLayout>
