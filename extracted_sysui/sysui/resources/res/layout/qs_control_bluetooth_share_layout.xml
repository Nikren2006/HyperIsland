<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_bluetooth_share"
    android:background="@drawable/bluetooth_share_bg_shape"
    android:layout_width="match_parent"
    android:layout_height="@dimen/miplay_bluetooth_share_height"
    android:layout_marginBottom="@dimen/miplay_bluetooth_share_marginBottom"
    android:layout_marginHorizontal="@dimen/miplay_bluetooth_share_marginHorizontal">
    <TextView
        android:textSize="@dimen/miplay_bluetooth_share_title_text_size"
        android:textColor="@color/miplay_bluetooth_share_title_text_color"
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/miplay_bluetooth_share_marginTop"
        android:text="@string/miplay_bluetooth_share_title_text"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/miplay_bluetooth_share_subTitle_text_size"
        android:textColor="@color/miplay_bluetooth_share_subTitle_text_color"
        android:id="@+id/subTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/miplay_bluetooth_share_subTitle_marginTop"
        android:text="@string/miplay_bluetooth_share_subTitle_text"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title"/>
    <ImageView
        android:id="@+id/icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/miplay_bluetooth_share_earPhone_icon_marginTop"
        android:src="@drawable/bluetooth_share_earphone_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/subTitle"/>
    <TextView
        android:textSize="@dimen/miplay_bluetooth_share_subTitle_text_size"
        android:textColor="@color/miplay_bluetooth_share_subTitle_text_color"
        android:gravity="center_horizontal"
        android:id="@+id/des"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/miplay_bluetooth_share_des_marginTop"
        android:text="@string/miplay_bluetooth_share_des_text"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/icon"/>
</androidx.constraintlayout.widget.ConstraintLayout>
