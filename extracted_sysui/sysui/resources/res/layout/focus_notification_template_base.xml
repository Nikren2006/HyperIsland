<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container"
    android:layout_width="match_parent"
    android:layout_height="@dimen/focus_notify_normal_height">
    <ImageView
        android:id="@+id/focus_notify_bg_image"
        android:layout_width="match_parent"
        android:layout_height="@dimen/focus_notify_normal_height"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/focus_main_column"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/focus_notify_margin_top_normal"
        android:layout_marginBottom="@dimen/focus_notify_margin_bottom_normal"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/focus_notify_margin_start_os2"
        android:layout_toStartOf="@+id/focus_right_container"
        android:layout_alignParentStart="true">
        <TextView
            android:id="@+id/focus_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/focus_title"
            style="@style/FocusNotifyTitleStyle"/>
        <TextView
            android:id="@+id/focus_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/focus_content"
            style="@style/FocusNotifyContentStyle"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:id="@+id/focus_right_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/focus_notify_text_action_gap"
        android:layout_marginEnd="@dimen/focus_notify_margin_end_normal"
        android:layout_alignParentEnd="true">
        <ImageView
            android:id="@+id/focus_button_icon1"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="@dimen/focus_notify_action_height"
            android:layout_height="@dimen/focus_notify_action_height"/>
        <ImageView
            android:id="@+id/focus_button_icon2"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="@dimen/focus_notify_action_height"
            android:layout_height="@dimen/focus_notify_action_height"
            android:layout_marginStart="10dp"/>
        <ImageView
            android:id="@+id/focus_large_icon"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="@dimen/focus_notify_large_pic_width"
            android:layout_height="@dimen/focus_notify_large_pic_height"
            android:importantForAccessibility="no"/>
    </LinearLayout>
</RelativeLayout>
