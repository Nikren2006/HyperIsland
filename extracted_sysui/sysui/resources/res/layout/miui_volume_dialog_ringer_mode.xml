<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.miui.volume.MiuiRingerModeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/miui_volume_ringer_layout"
    android:background="@drawable/miui_volume_dialog_background"
    android:clickable="true"
    android:clipChildren="false"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/miui_volume_footer_margin_top"
    android:layoutDirection="ltr">
    <FrameLayout
        android:id="@+id/miui_ringer_state_layout"
        android:clipChildren="false"
        android:layout_width="@dimen/miui_volume_silence_button_width"
        android:layout_height="@dimen/miui_volume_silence_button_height">
        <LinearLayout
            android:orientation="@integer/miui_volume_ringer_layout_orientation"
            android:id="@+id/miui_ringer_btn_layout"
            android:clipChildren="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false">
            <include
                android:id="@+id/ringer_layout"
                layout="@layout/miui_ringer_mode_layout"/>
            <View
                android:id="@+id/miui_volume_ringer_divider"
                android:layout_width="@dimen/miui_volume_ringer_divider_width"
                android:layout_height="@dimen/miui_volume_ringer_divider_height"/>
            <include
                android:id="@+id/dnd_layout"
                layout="@layout/miui_ringer_mode_layout"/>
        </LinearLayout>
    </FrameLayout>
</com.android.systemui.miui.volume.MiuiRingerModeLayout>
