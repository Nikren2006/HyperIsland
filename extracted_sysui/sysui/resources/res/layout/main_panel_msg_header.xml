<?xml version="1.0" encoding="utf-8"?>
<miui.systemui.widget.FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/msg_header_container"
    android:focusable="false"
    android:clickable="false"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:importantForAccessibility="no">
    <miui.systemui.widget.ConstraintLayout
        android:id="@+id/msg_header"
        android:focusable="false"
        android:clickable="false"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no">
        <Space
            android:id="@+id/reference_space"
            android:layout_width="0dp"
            android:layout_height="@dimen/header_qs_message_reference_height"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <miui.systemui.widget.TextView
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:id="@+id/header_msg_a"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:alpha="1"
            app:layout_constraintBottom_toBottomOf="@+id/reference_space"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/reference_space"
            app:layout_constraintVertical_bias="0.3"
            style="@style/TextAppearance.QS.HeaderMessage"/>
        <miui.systemui.widget.TextView
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:id="@+id/header_msg_b"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:alpha="1"
            app:layout_constraintBottom_toBottomOf="@+id/reference_space"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/reference_space"
            app:layout_constraintVertical_bias="0.3"
            style="@style/TextAppearance.QS.HeaderMessage"/>
    </miui.systemui.widget.ConstraintLayout>
</miui.systemui.widget.FrameLayout>
