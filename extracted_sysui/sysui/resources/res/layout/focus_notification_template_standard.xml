<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container"
    android:clipChildren="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/area_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <RelativeLayout
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/focus_notify_template_margin">
        <FrameLayout
            android:id="@+id/area_c"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"/>
        <FrameLayout
            android:id="@+id/area_a"
            android:clipChildren="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/focus_notify_template_margin_inner_hor_v2"
            android:layout_toStartOf="@+id/area_c"
            android:layout_alignParentStart="true"/>
        <FrameLayout
            android:id="@+id/area_d"
            android:paddingTop="@dimen/focus_notify_template_margin_inner"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/area_a"/>
    </RelativeLayout>
</FrameLayout>
