<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/progressbar_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:importantForAccessibility="no"
    android:layout_marginHorizontal="@dimen/focus_notify_module_margin_horizontal">
    <ProgressBar
        android:layout_gravity="bottom"
        android:id="@+id/focus_progress_info1"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/focus_notify_module_progress_height"
        android:layout_marginBottom="4dp"
        android:progressDrawable="@drawable/progressbar_line_style_v2"
        style="?android:attr/progressBarStyleHorizontal"/>
    <ProgressBar
        android:layout_gravity="bottom"
        android:id="@+id/focus_progress_info2"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/focus_notify_module_progress_height"
        android:layout_marginBottom="4dp"
        android:progressDrawable="@drawable/progressbar_style_v2"
        style="?android:attr/progressBarStyleHorizontal"/>
    <ImageView
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/progress_point1"
        android:visibility="gone"
        android:layout_width="@dimen/focus_notify_progress_position_icon_width"
        android:layout_height="@dimen/focus_notify_progress_icon_height"/>
    <ImageView
        android:layout_gravity="end|bottom"
        android:id="@+id/progress_point2"
        android:layout_width="@dimen/focus_notify_progress_position_icon_width"
        android:layout_height="@dimen/focus_notify_progress_icon_height"/>
    <ImageView
        android:layout_gravity="start|bottom"
        android:id="@+id/progress_icon"
        android:layout_width="@dimen/focus_notify_progress_icon_width"
        android:layout_height="@dimen/focus_notify_progress_icon_height"
        android:scaleType="fitXY"/>
</FrameLayout>
