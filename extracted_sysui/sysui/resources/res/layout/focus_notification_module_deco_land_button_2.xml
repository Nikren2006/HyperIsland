<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container_module_button_2"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp">
    <FrameLayout
        android:id="@+id/line"
        android:background="@color/lineColor"
        android:layout_width="match_parent"
        android:layout_height="@dimen/focus_notify_line_height"
        android:layout_marginEnd="4dp"/>
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:id="@+id/ll_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="5dp"
        android:baselineAligned="false">
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/layout_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp">
            <FrameLayout
                android:orientation="vertical"
                android:id="@+id/title_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/focus_small_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:fontFamily="mipro-demibold"
                    style="@style/FocusNotifyDecoLandSmallTitleStyleV2"/>
                <miuix.colorful.texteffect.HyperChronometer
                    android:id="@+id/chronometer_hint"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/FocusNotifyDecoLandSmallChronometerStyleV2"/>
            </FrameLayout>
            <TextView
                android:id="@+id/focus_small_subtitle"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                style="@style/FocusNotifyDecoLandSmallTitleStyleV2"/>
        </LinearLayout>
        <include
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            layout="@layout/focus_notification_module_deco_land_mark_4"/>
    </LinearLayout>
</FrameLayout>
