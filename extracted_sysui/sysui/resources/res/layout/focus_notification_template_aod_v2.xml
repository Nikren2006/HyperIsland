<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container"
    android:background="@drawable/focus_aod_background_v2"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/focus_aod_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="10dp"
        android:layout_marginVertical="10dp"/>
    <TextView
        android:layout_gravity="center_vertical"
        android:id="@+id/focus_aod_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/focus_title"
        android:maxEms="8"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="12dp"
        android:paddingVertical="@dimen/focus_notify_title_margin_vertical"
        style="@style/FocusNotifyAODTitleStyleV2"/>
</LinearLayout>
