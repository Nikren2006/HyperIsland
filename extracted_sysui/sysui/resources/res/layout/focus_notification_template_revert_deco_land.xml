<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_container"
    android:layout_width="@dimen/focus_notify_deco_land_width"
    android:layout_height="@dimen/focus_notify_deco_land_height">
    <ImageView
        android:id="@+id/focus_notify_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/focus_main_column"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/focus_notify_deco_land_cm_container_margin_top"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="@dimen/focus_notify_deco_land_cm_container_margin">
        <TextView
            android:id="@+id/focus_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/focus_content"
            style="@style/FocusNotifyDecoContentStyle"/>
        <TextView
            android:textSize="22dp"
            android:id="@+id/focus_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/focus_title"
            android:fontFamily="mipro-medium"
            style="@style/FocusNotifyTitleStyle"/>
        <Chronometer
            android:id="@+id/chronometer"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/FocusNotifyCmStyle"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="end|center_vertical"
        android:id="@+id/focus_right_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1.5dp"
        android:layout_below="@+id/focus_main_column"
        android:layout_centerHorizontal="true">
        <ImageView
            android:id="@+id/focus_button_icon1"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <ImageView
            android:id="@+id/focus_button_icon2"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/focus_notify_deco_land_button_margin"/>
    </LinearLayout>
</RelativeLayout>
