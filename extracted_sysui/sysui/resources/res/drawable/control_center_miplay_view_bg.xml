<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@+id/background">
        <shape>
            <corners android:radius="@dimen/miplay_view_bg_radius"/>
            <solid android:color="@color/miplay_view_bg_color"/>
        </shape>
    </item>
    <item android:id="@+id/clip_layer">
        <shape>
            <corners android:radius="@dimen/miplay_view_bg_radius"/>
            <solid android:color="@color/miplay_view_bg_color_overlay"/>
        </shape>
    </item>
</layer-list>
